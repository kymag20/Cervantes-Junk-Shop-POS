# Rename this file to .env, then replace the sample values.
DEBUG=True
SECRET_KEY=change-this-before-online-deploy
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
TIME_ZONE=Asia/Manila

# Optional. Leave blank for local SQLite.
# To make VS Code/local use the same accounts as Render, paste Render's
# PostgreSQL External Database URL here.
DATABASE_URL=

# Optional fallback for production only if you use a persistent disk.
# Leave blank for normal local development.
SQLITE_PATH=

GMAIL_ADDRESS=youraccount@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
